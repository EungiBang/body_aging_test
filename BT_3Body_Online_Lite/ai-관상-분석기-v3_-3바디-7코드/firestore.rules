rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Primitives
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid'])
        && data.keys().size() <= 10 // Increased limit for flexibility
        && data.uid is string && data.uid.size() <= 128
        && data.uid == request.auth.uid
        && (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100)
        && (data.get('phoneNumber', '') is string && data.get('phoneNumber', '').size() <= 20)
        && (data.get('birthDate', '') is string && data.get('birthDate', '').size() <= 10)
        && (data.get('gender', '') is string && data.get('gender', '').size() <= 10)
        && (data.get('createdAt', request.time) is timestamp)
        && (data.get('updatedAt', request.time) is timestamp);
    }
    
    function isValidReport(data, userId) {
      return data.keys().hasAll(['userId', 'summary', 'score', 'createdAt'])
        // Skipping detailed schema validation for complex nested objects for now, 
        // to simplify the example. But we enforce base fields.
        && data.userId is string && data.userId == userId
        && data.summary is string && data.summary.size() <= 1000
        && data.score is number
        && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create: if isSignedIn() 
                    && request.auth.uid == userId 
                    && isValidId(userId)
                    && isValidUser(incoming());
      allow update: if isSignedIn() 
                    && request.auth.uid == userId 
                    && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().uid == existing().uid
                    // Allow updating profile fields
                    && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phoneNumber', 'birthDate', 'gender', 'updatedAt']);
    }
    
    match /users/{userId}/reports/{reportId} {
      allow read: if isSignedIn() 
                  && request.auth.uid == userId 
                  && isValidId(userId) 
                  && isValidId(reportId)
                  // No blanket list constraint (enforced by userId match)
                  && (resource == null || resource.data.userId == request.auth.uid);

      allow list: if isSignedIn() 
                  && request.auth.uid == userId
                  && isValidId(userId);
                  // && resource.data.userId == request.auth.uid;  - resource.data does not exist in `list` requests if they only check path

      allow create: if isSignedIn() 
                    && request.auth.uid == userId 
                    && isValidId(userId)
                    && isValidId(reportId)
                    && isValidReport(incoming(), userId)
                    && exists(/databases/$(database)/documents/users/$(userId));
      
      allow delete: if isSignedIn() 
                    && request.auth.uid == userId;
    }
  }
}
