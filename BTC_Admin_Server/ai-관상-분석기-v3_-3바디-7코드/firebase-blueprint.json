{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string", "nullable": true },
        "phoneNumber": { "type": "string", "nullable": true },
        "birthDate": { "type": "string", "nullable": true },
        "gender": { "type": "string", "nullable": true },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Report": {
      "title": "Physiognomy Report",
      "description": "A saved face analysis report",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "summary": { "type": "string" },
        "score": { "type": "number" },
        "confidenceScore": { "type": "number" },
        "samjeongAnalysis": { "type": "string" },
        "personality": { "type": "string" },
        "wealthAndCareer": { "type": "string" },
        "animalMorphology": { "type": "object" },
        "energy3Body7Code": { "type": "object" },
        "traditionalAnalysis": { "type": "object" },
        "lifeStrategy": { "type": "object" },
        "advice": { "type": "string" },
        "imageThumbnail": { "type": "string", "nullable": true, "description": "Base64 thumbnail if available" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "summary", "score", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Store basic user profile information."
    },
    "/users/{userId}/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "Store analysis reports linked to a user. Restricted to the owner."
    }
  }
}
