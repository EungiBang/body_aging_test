{
  "name": "btc-3body-ai-analyzer",
  "private": true,
  "version": "5.1.4",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "BTC 3바디 AI분석기 - AI 신체 균형 & 건강 상태 체력 측정 시스템",
  "author": "Brain Training Center",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:3001 && electron .\"",
    "electron:build": "vite build && electron-builder --win",
    "electron:build:dir": "vite build && electron-builder --win --dir",
    "electron:publish": "vite build && electron-builder --win -p always"
  },
  "build": {
    "appId": "com.btc.3body-ai-analyzer",
    "productName": "BTC 3바디 AI분석기",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/node-machine-id/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BTC 3바디 AI 건강센터"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "EungiBang",
        "repo": "body_aging_test",
        "releaseType": "release"
      }
    ],
    "artifactName": "BTC_3Body_AI_Analyzer_v${version}.${ext}"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@mediapipe/selfie_segmentation": "^0.1.1675465747",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@tensorflow-models/body-segmentation": "^1.0.2",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "electron-updater": "^6.8.3",
    "firebase": "^12.11.0",
    "node-machine-id": "^1.1.12",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "remark-gfm": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-static-copy": "^4.1.0",
    "wait-on": "^8.0.3"
  }
}
